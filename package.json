{
  "name": "vue-superbase-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "migrate": "node scripts/migrate.cjs",
    "migrate:new": "node scripts/migrate.cjs new",
    "migrate:push": "node scripts/migrate.cjs push",
    "migrate:pull": "node scripts/migrate.cjs pull",
    "migrate:list": "node scripts/migrate.cjs list",
    "migrate:status": "node scripts/migrate.cjs status",
    "migrate:repair": "node scripts/migrate.cjs repair",
    "migrate:ddl": "node scripts/migrate.cjs ddl"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@supabase/supabase-js": "^2.110.6",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/vue-table": "^8.21.3",
    "@unovis/ts": "^1.6.7",
    "@unovis/vue": "^1.6.7",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.1",
    "shadcn-vue": "^2.8.0",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/eslint-plugin": "^1.6.23",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "postcss": "^8.5.19",
    "prettier": "3.8.3",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
